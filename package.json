{
  "name": "emergency-response-navigator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-data.mjs && tsc -b && vite build",
    "build:data": "node scripts/build-data.mjs",
    "preview": "vite preview",
    "build:protected": "npm run build && npx staticrypt dist/index.html -p ${SITE_PASSWORD:-changeme} --short -d dist"
  },
  "dependencies": {
    "@orama/orama": "^3.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "csv-parse": "^5.6.0",
    "postcss": "^8.4.0",
    "staticrypt": "^3.5.4",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
